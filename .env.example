# Google Spreadsheet ID (from the URL: /spreadsheets/d/<ID>/edit)
GOOGLE_SPREADSHEET_ID=1U-T91N__ouV1EmnaCDcJPq_0Ta3OlutI7chizUMgRTc

# Google Auth — pick ONE of these two options:
#
# Option A (recommended for local dev): Application Default Credentials
#   Run once: gcloud auth application-default login
#   Nothing else needed here.
#
# Option B: Service Account JSON key (for deployed environments)
#   Paste the full JSON as a single-line string
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# Redshift (only needed if running the warehouse sync job)
# REDSHIFT_URL=postgres://user:pass@cluster.redshift.amazonaws.com:5439/dev
# REDSHIFT_WAREHOUSE_QUERY=SELECT id, name, location_code, region, is_active FROM warehouses

# Cron auth (only needed for /api/cron/sync-warehouses)
# CRON_SECRET=replace-with-random-string
